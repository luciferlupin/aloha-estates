# ==========================================
# Aloha Estates CRM Environment Variables
# Copy this file to a new file named '.env' and fill in variables
# ==========================================

# 1. Supabase Cloud Configuration Keys
# Obtain these from Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-supabase-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# 2. Meta Ads Webhook Integration Configuration
# Shared verification token used to approve the webhook connection with Meta Ads Manager
META_VERIFY_TOKEN=aloha_estates_meta_verify_token_123

# Access token to download Meta Lead Form payloads (obtain from Meta Graph API Explorer)
META_ACCESS_TOKEN=EAABw...your-meta-access-token
